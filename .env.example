# Copie para .env na VPS e preencha. Não commite .env com segredos.

NODE_ENV=production
PORT=3000

# Obrigatório em produção: string longa e aleatória (ex.: openssl rand -hex 32)
SESSION_SECRET=

# Com NODE_ENV=production o cookie de sessão é "Secure" (só HTTPS). Se você acessa o Node
# direto em HTTP (ex.: http://IP:3000), o login não grava sessão — use false só nesse caso:
# SESSION_COOKIE_SECURE=false

# URL pública do site, sem barra no final (retorno Mercado Pago e e-mails)
APP_PUBLIC_URL=https://seudominio.com.br

# Opcional: caminho absoluto do SQLite (padrão: pasta do projeto)
# SQLITE_PATH=/var/www/gympaquera/data/app.db

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
# URL HTTPS pública do webhook (ex.: https://seudominio.com.br/api/payments/webhook)
MERCADOPAGO_WEBHOOK_URL=
MERCADOPAGO_SANDBOX=false

# Plano (opcional)
# PREMIUM_PRICE_BRL=9.9
# PREMIUM_DAYS=30

# E-mail (SMTP obrigatório para enviar: esqueci senha, denúncias, notificações)
# Exemplo Hostinger / provedor próprio:
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contato@seudominio.com
# SMTP_PASS=
# MAIL_FROM=contato@seudominio.com
#
# Exemplo Gmail (use "Senha de app" em conta Google, não a senha normal):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=gympaquera@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=gympaquera@gmail.com
#
# Para onde vão as denúncias (padrão gympaquera@gmail.com se vazio):
# REPORTS_TO_EMAIL=gympaquera@gmail.com

# Se o proxy não for detectado automaticamente:
# TRUST_PROXY=1
