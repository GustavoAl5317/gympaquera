# Copie para .env na VPS e preencha. Não commite .env com segredos.

NODE_ENV=production
PORT=3000

# Obrigatório em produção: string longa e aleatória (ex.: openssl rand -hex 32)
SESSION_SECRET=

# URL pública do site, sem barra no final (retorno Mercado Pago e e-mails)
APP_PUBLIC_URL=https://seudominio.com.br

# Opcional: caminho absoluto do SQLite (padrão: pasta do projeto)
# SQLITE_PATH=/var/www/gympaquera/data/app.db

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
# URL HTTPS pública do webhook (ex.: https://seudominio.com.br/api/payments/webhook)
MERCADOPAGO_WEBHOOK_URL=
MERCADOPAGO_SANDBOX=false

# Plano (opcional)
# PREMIUM_PRICE_BRL=9.9
# PREMIUM_DAYS=30

# E-mail (notificações e link "esqueci a senha" — sem SMTP o reset não envia o e-mail)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=

# Se o proxy não for detectado automaticamente:
# TRUST_PROXY=1
